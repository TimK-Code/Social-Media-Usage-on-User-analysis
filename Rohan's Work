## Multiple Linear Regression

```{r mlr-fit}
selected_vars <- lasso_df$Variable
selected_vars <- selected_vars[selected_vars %in% colnames(insta_clean)]

mlr_formula <- as.formula(
  paste("self_reported_happiness ~", paste(selected_vars, collapse = " + "))
)
mlr_model   <- lm(mlr_formula, data = insta_clean)
mlr_summary <- summary(mlr_model)
```

### Graph 3 — MLR: Coefficient Estimates

```{r plot-mlr-coefs, fig.width=8, fig.height=5}
mlr_coefs <- as.data.frame(mlr_summary$coefficients)
mlr_coefs$Variable    <- rownames(mlr_coefs)
mlr_coefs$Significant <- mlr_coefs$`Pr(>|t|)` < 0.05
mlr_coefs <- filter(mlr_coefs, Variable != "(Intercept)")

ggplot(mlr_coefs, aes(x = reorder(Variable, Estimate),
                      y = Estimate, fill = Significant)) +
  geom_col() +
  geom_errorbar(
    aes(ymin = Estimate - 1.96 * `Std. Error`,
        ymax = Estimate + 1.96 * `Std. Error`),
    width = 0.3, color = "gray30"
  ) +
  scale_fill_manual(
    values = c("TRUE" = "#4E79A7", "FALSE" = "#BAB0AC"),
    labels = c("TRUE" = "p < 0.05", "FALSE" = "p >= 0.05")
  ) +
  coord_flip() +
  labs(
    title    = "MLR: Coefficient Estimates with 95% Confidence Intervals",
    subtitle = "Only LASSO-selected variables included | Blue = statistically significant",
    x        = "Predictor",
    y        = "Coefficient Estimate",
    fill     = "Significance"
  ) +
  theme_minimal(base_size = 13) +
  theme(
    plot.title      = element_text(face = "bold"),
    plot.subtitle   = element_text(color = "gray40"),
    legend.position = "bottom"
  )
```

### Graph 4 — MLR: Actual vs. Predicted

```{r plot-mlr-actual-vs-pred, fig.width=8, fig.height=5}
set.seed(42)
plot_idx <- sample(nrow(insta_clean), min(5000, nrow(insta_clean)))

pred_df <- data.frame(
  Actual    = insta_clean$self_reported_happiness[plot_idx],
  Predicted = fitted(mlr_model)[plot_idx]
)

ggplot(pred_df, aes(x = Actual, y = Predicted)) +
  geom_point(alpha = 0.15, size = 0.7, color = "#4E79A7") +
  geom_abline(slope = 1, intercept = 0, color = "red",
              linetype = "dashed", linewidth = 0.9) +
  labs(
    title    = "MLR: Actual vs. Predicted Happiness",
    subtitle = paste0("R-squared = ", round(mlr_summary$r.squared, 3),
                      " | Red line = perfect prediction | n = 5,000 plotted"),
    x        = "Actual Happiness Score",
    y        = "Predicted Happiness Score"
  ) +
  theme_minimal(base_size = 13) +
  theme(
    plot.title    = element_text(face = "bold"),
    plot.subtitle = element_text(color = "gray40")
  )
```



