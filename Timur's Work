# Model Diagnostics

## Predicted vs. Actual

```{r diag-plots, fig.height=4}
diag_df <- data.frame(
  actual    = c(test$self_reported_happiness, test$perceived_stress_score),
  predicted = c(pred_happiness, pred_stress),
  model     = rep(c("Happiness Score", "Stress Score"), each = nrow(test))
)

ggplot(diag_df, aes(x = actual, y = predicted, colour = model)) +
  geom_point(alpha = 0.15, size = 0.6) +
  geom_abline(slope = 1, intercept = 0, linetype = "dashed",
              colour = "black", linewidth = 0.8) +
  facet_wrap(~model, scales = "free") +
  scale_colour_manual(values = c("#1565C0", "#C62828")) +
  labs(title = "Predicted vs. Actual Values — Test Set",
       x = "Actual Score", y = "Predicted Score") +
  theme_minimal(base_size = 13) +
  theme(legend.position = "none")
```

## OOB Error vs. Number of Trees

```{r oob-plot, fig.height=4}
oob_df <- data.frame(
  trees     = seq_len(rf_happiness$ntree),
  Happiness = rf_happiness$mse,
  Stress    = rf_stress$mse
) %>%
  pivot_longer(-trees, names_to = "Model", values_to = "OOB_MSE")

ggplot(oob_df, aes(x = trees, y = OOB_MSE, colour = Model)) +
  geom_line(linewidth = 0.9) +
  scale_colour_manual(values = c("#1565C0", "#C62828")) +
  labs(title = "OOB Error vs. Number of Trees",
       x = "Number of Trees", y = "OOB MSE", colour = "Model") +
  theme_minimal(base_size = 13)
```

